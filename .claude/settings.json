{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "NotebookEdit",
      "TodoWrite",
      "Bash",
      "Bash(*)",
      "PowerShell",
      "PowerShell(*)",
      "mcp__*"
    ],
    "deny": []
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"[System.Media.SystemSounds]::Exclamation.Play()\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
