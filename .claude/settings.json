{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "NotebookEdit",
      "TodoWrite",
      "Bash(*)",
      "PowerShell(*)"
    ],
    "deny": [
      "Bash(supabase project delete*)",
      "PowerShell(supabase project delete*)",
      "Bash(vercel project rm*)",
      "PowerShell(vercel project rm*)",
      "Bash(vercel domains rm*)",
      "PowerShell(vercel domains rm*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"[System.Media.SystemSounds]::Exclamation.Play()\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
